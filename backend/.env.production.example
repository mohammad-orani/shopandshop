# ==================== NEW BRAND — PRODUCTION ENVIRONMENT TEMPLATE ====================
# Copy this to backend/.env on the server hosting the NEW brand's deployment.
# It must point at a brand-new, empty MySQL database — never the old Primejo
# database. Fill in every blank value before starting the server.
#
# Note on variable names: the requested DATABASE_NAME / DATABASE_USER /
# DATABASE_PASSWORD are provided here as DB_NAME / DB_USER / DB_PASSWORD —
# those are the exact names backend/db.js reads via process.env. Renaming
# them in code would go against "keep current architecture", so use the
# names below as-is.

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (MySQL) — new, empty database for this brand ───────────────────────
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# ── Auth ─────────────────────────────────────────────────────────────────────────
# REQUIRED — generate a strong random secret (do not reuse the old brand's secret):
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Store / Brand ────────────────────────────────────────────────────────────────
STORE_NAME=
STORE_EMAIL=
STORE_PHONE=
STORE_DOMAIN=

# ── WhatsApp Notifications (CallMeBot) — optional ────────────────────────────────
CALLMEBOT_APIKEY=

# ── WhatsApp Broadcast (Twilio) — optional ───────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ADMIN_WHATSAPP=

# ── Email Notifications (SendGrid) — optional ────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM=

# ── Payments (Stripe) — optional, only needed for the mobile app checkout ───────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
