# ==================== SHOP & SHOP BACKEND — ENVIRONMENT VARIABLES ====================
# Copy this file to .env and fill in your values. Never commit .env to source control.

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3000

# ── Database (MySQL) ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=railway

# ── Auth ─────────────────────────────────────────────────────────────────────────
# REQUIRED — generate a strong random secret:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── WhatsApp Notifications (CallMeBot) ───────────────────────────────────────────
CALLMEBOT_APIKEY=

# ── Email Notifications (SendGrid) ───────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM=orders@yourstore.com

# ── Image Storage (product/banner uploads — backend/storage/) ───────────────────
# STORAGE_DRIVER selects where POST /api/upload writes files: "local" (default,
# no other setup needed — writes to backend/public/uploads, served via
# express.static) or "r2" (Cloudflare R2, needs the R2_* vars below).
#
# ⚠ On Railway (and most PaaS), local disk is ephemeral and is wiped on every
# redeploy — anything uploaded is lost the next time the service redeploys.
# "local" is fine for local development or a host with persistent disk; for
# Railway/most PaaS, set STORAGE_DRIVER=r2.
STORAGE_DRIVER=local

# Only read when STORAGE_DRIVER=r2. Create a bucket at dash.cloudflare.com → R2,
# then an API token scoped to it (R2 → Manage API Tokens). R2_ACCOUNT_ID is
# shown on the R2 overview page. R2_PUBLIC_URL is the bucket's public read
# URL — either the r2.dev subdomain Cloudflare gives you after enabling
# "Public Access" on the bucket, or a custom domain you've mapped to it. No
# trailing slash.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Store / Brand ────────────────────────────────────────────────────────────────
# Single source of truth for brand text used in server-generated messages
# (WhatsApp notifications, Stripe order descriptions, CORS allowlist, startup log).
STORE_NAME=Shop and Shop
STORE_EMAIL=info@yourstore.com
STORE_PHONE=+10000000000
# Primary storefront domain (no protocol/subdomain) — used to build the CORS allowlist
STORE_DOMAIN=shopandshop.online
