{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start Backend API",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/backend/server.js",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open Frontend with Chrome",
      "url": "http://127.0.0.1:5500/frontend/index.html",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "Open Admin Panel with Chrome",
      "url": "http://127.0.0.1:5500/admin/index.html",
      "webRoot": "${workspaceFolder}/admin"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Backend + Frontend",
      "configurations": [
        "Start Backend API",
        "Open Frontend with Chrome"
      ]
    }
  ]
}
