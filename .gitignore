# Node modules
node_modules/
npm-debug.log*

# Environment variables
.env

# Environment backend
backend/.env

# Environment frontend
frontend/.env

# Environment admin
admin/.env

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log

# Database
*.sql.backup
*.db

# Uploads — user-generated product images (backend/routes/upload.js), served
# via express.static('public') at /uploads/products/*. Not committed; the
# directory is created automatically at runtime (fs.mkdirSync in upload.js).
uploads/*
!uploads/.gitkeep
backend/public/uploads/*
!backend/public/uploads/.gitkeep

# Build files
dist/
build/

# Exception: frontend/dist/ is committed, not generated at deploy time — this
# static site has no build step, so the minified CSS/JS it references must
# ship in the repo. Regenerate with `npm run build` after editing any source
# .css/.js file in frontend/.
!frontend/dist/
!frontend/dist/**

# Temporary files
*.tmp
*.temp
