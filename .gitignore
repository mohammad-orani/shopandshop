# Node modules
node_modules/
npm-debug.log*

# Environment variables
.env

# Environment backend
backend/.env

# Environment frontend
frontend/.env

# Environment admin
admin/.env

# OS files
.DS_Store
Thumbs.db

# Editor directories and files
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
logs/
*.log

# Database
*.sql.backup
*.db

# Uploads (if implemented)
uploads/*
!uploads/.gitkeep

# Build files
dist/
build/

# Exception: frontend/dist/ is committed, not generated at deploy time — this
# static site has no build step, so the minified CSS/JS it references must
# ship in the repo. Regenerate with `npm run build` after editing any source
# .css/.js file in frontend/.
!frontend/dist/
!frontend/dist/**

# Temporary files
*.tmp
*.temp
